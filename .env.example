# ─── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/coffeelab?schema=public"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis (BullMQ background jobs) ────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Email (Nodemailer / SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM="The Coffee Lab <noreply@thecoffeelab.pk>"

# ─── WhatsApp (WATI / Meta Cloud API) ─────────────────────────────────────────
WATI_API_URL=https://live-mt-server.wati.io
WATI_API_TOKEN=your_wati_token

# ─── SMS (Twilio or local provider) ────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── FBR ───────────────────────────────────────────────────────────────────────
FBR_API_URL=https://gw.fbr.gov.pk/imsp/v1
FBR_API_KEY=

# ─── File Storage (S3-compatible) ──────────────────────────────────────────────
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_BUCKET=coffeelab-assets
S3_REGION=sgp1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=https://coffeelab-assets.sgp1.digitaloceanspaces.com
